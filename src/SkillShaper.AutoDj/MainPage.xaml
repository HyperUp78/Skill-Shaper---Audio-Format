<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SkillShaper.AutoDj.MainPage"
             Title="SkillShaper AutoDJ"
             BackgroundColor="#111318">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label x:Name="StatusLabel"
                   Text="Ready. Tap Scan to load MP3 tracks."
                   TextColor="White"
                   FontSize="14" />

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button Grid.Column="0"
                        Text="Scan"
                        Clicked="OnScanClicked" />
                <Button Grid.Column="1"
                        Text="Start AutoMix"
                        Clicked="OnStartAutoMixClicked" />
                <Button Grid.Column="2"
                        Text="Stop AutoMix"
                        Clicked="OnStopAutoMixClicked" />
            </Grid>

            <VerticalStackLayout x:Name="DeckHost" Spacing="12" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
